<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NativePlayer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NativePlayer">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--
            视频画面承载控件。C++ 端会拿到它的 ISwapChainPanelNative 接口，
            把 ANGLE/EGL 创建的 D3D11 swapchain 绑定到它上面。
        -->
        <SwapChainPanel
            x:Name="VideoPanel"
            Grid.Row="0"
            SizeChanged="VideoPanel_SizeChanged" />

        <!-- 阶段1的最小控制条：打开文件 / 播放-暂停 -->
        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="12"
            Padding="12"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Button x:Name="OpenFileButton" Content="打开文件" Click="OpenFileButton_Click" />
            <Button x:Name="PlayPauseButton" Content="播放/暂停" Click="PlayPauseButton_Click" />
            <TextBlock x:Name="StatusText" Text="未加载文件" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
